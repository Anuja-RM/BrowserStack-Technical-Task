<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">

<suite name="BrowserStack Suite" parallel="tests" thread-count="5">

    <!-- Desktop 1 -->
    <test name="Chrome Windows">
        <parameter name="browser" value="Chrome"/>
        <parameter name="browserVersion" value="latest"/>
        <parameter name="os" value="Windows"/>
        <parameter name="osVersion" value="11"/>
        <parameter name="deviceName" value=""/>
        <classes>
            <class name="BrowserStackTest"/>
        </classes>
    </test>

    <!-- Desktop 2 -->
    <test name="Edge Windows">
        <parameter name="browser" value="Edge"/>
        <parameter name="browserVersion" value="latest"/>
        <parameter name="os" value="Windows"/>
        <parameter name="osVersion" value="11"/>
        <parameter name="deviceName" value=""/>
        <classes>
            <class name="BrowserStackTest"/>
        </classes>
    </test>

    <!-- Desktop 3 -->
    <test name="Safari Mac">
        <parameter name="browser" value="Safari"/>
        <parameter name="browserVersion" value="latest"/>
        <parameter name="os" value="OS X"/>
        <parameter name="osVersion" value="Ventura"/>
        <parameter name="deviceName" value=""/>
        <classes>
            <class name="BrowserStackTest"/>
        </classes>
    </test>

    <!-- Mobile 1 -->
    <test name="iPhone 14">
        <parameter name="browser" value=""/>
        <parameter name="browserVersion" value=""/>
        <parameter name="os" value=""/>
        <parameter name="osVersion" value=""/>
