        <classes>
            <class name="BrowserStackTest"/>
        </classes>
    </test>

    <!-- Mobile 2 -->
    <test name="Samsung Galaxy S23">
        <parameter name="browser" value=""/>
        <parameter name="browserVersion" value=""/>
        <parameter name="os" value=""/>
        <parameter name="osVersion" value=""/>
        <parameter name="deviceName" value="Samsung Galaxy S23"/>
        <classes>
            <class name="BrowserStackTest"/>
        </classes>
    </test>

</suite>